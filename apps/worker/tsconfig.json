{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "ES2023.Array"],
    "types": ["@cloudflare/workers-types"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "paths": {
      "@auction/shared": ["../../packages/shared/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"]
}
