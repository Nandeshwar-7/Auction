# ── PostgreSQL (Prisma + Worker local Hyperdrive) ────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/auction?schema=public"

# Optional: override Hyperdrive local connection only (defaults to DATABASE_URL)
# WRANGLER_HYPERDRIVE_LOCAL_CONNECTION_STRING_DB="postgresql://..."

# ── Cloudflare Worker (apps/worker) — read by `npm run dev` in @auction/worker ─
# Written to apps/worker/.dev.vars for Wrangler; also used for Hyperdrive via DATABASE_URL above.
SESSION_COOKIE_NAME=auction_session
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Next.js (apps/web) ────────────────────────────────────────────────────────
NEXT_PUBLIC_AUCTION_API_URL=http://localhost:8787
NEXT_PUBLIC_AUCTION_WS_URL=ws://localhost:8787

NEXT_ALLOWED_DEV_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Production Worker ──────────────────────────────────────────────────────────
# Set Hyperdrive id in apps/worker/wrangler.toml and configure vars in the Cloudflare dashboard
# (ALLOWED_ORIGINS, SESSION_COOKIE_NAME) or add a [vars] block / env-specific wrangler config.
